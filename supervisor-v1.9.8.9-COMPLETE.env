# =========================================================
# VPROFESSOR v1.9.8.9, COMPLETE PRODUCTION ENVIRONMENT
# Delete the old Render variables, then import this file.
# Use the same configuration for the Web Service and Worker.
# Replace every REPLACE_* value before deployment.
# =========================================================

# ---------- Runtime ----------
PYTHON_VERSION=3.12.11
LOG_LEVEL=INFO

# ---------- Administrator bootstrap ----------
# These values create the initial administrator only when one does not exist.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_ADMIN_PASSWORD
ADMIN_NAME="System Administrator"
ADMIN_EMAIL=aadam@ucc.edu.gh

# ---------- Security ----------
# Generate a new random secret. Do not reuse the previously exposed value.
SESSION_SECRET=REPLACE_WITH_A_NEW_RANDOM_64_CHARACTER_SECRET
COOKIE_SECURE=true

# ---------- Database and persistent storage ----------
# Recommended when using the Render persistent disk mounted at /var/data.
# Replace this line with Render's PostgreSQL DATABASE_URL when using PostgreSQL.
DATABASE_URL=sqlite:////var/data/supervisor.db
REVIEW_STORAGE_DIR=/var/data/reviews
REVIEW_STORAGE_FALLBACK_DIR=/tmp/projectready-supervisor/reviews

# ---------- Provider credentials ----------
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- Cost-aware routing ----------
AI_REVIEW_ENABLED=true
VPROF_ROUTING_PROFILE=quality
VPROF_ENABLE_OPENAI=false
VPROF_ENABLE_DEEPSEEK=true
VPROF_ENABLE_SELECTIVE_ESCALATION=false
VPROF_ESCALATE_CONFIDENCE_BELOW=0.78
VPROF_DEFAULT_CALL_BUDGET_USD=0.25
VPROF_EXTERNAL_CALL_BUDGET_USD=2.00
VPROF_ALL_LEVELS_DEGREE_CALIBRATED=true
VPROF_RESEARCH_MASTERS_DEEP_REVIEW=true

# ---------- Expert DeepSeek V4 Pro-only route ----------
# Enables one stronger DeepSeek Pro route for all supervisory review stages.
VPROF_EXPERT_PROVIDER_MODE=deepseek_v4_pro_only
VPROF_FORCE_DEEPSEEK_V4_PRO=true

# ---------- Public comment quality controls ----------
VPROF_REJECT_PLACEHOLDER_COMMENTS=true
VPROF_SUPPRESS_INTERNAL_AUDIT_NOTICES=true
VPROF_COMMENT_MAX_CHARS=980
VPROF_COMMENT_SIMILARITY_THRESHOLD=0.58
VPROF_DEVELOPMENTAL_COMMENTS=true
VPROF_COMMENT_DEPTH_FLOOR_ENABLED=true
VPROF_STANDARD_NON_RESEARCH_MIN_FINDINGS=14
VPROF_STANDARD_RESEARCH_MASTERS_MIN_FINDINGS=22
VPROF_STANDARD_PROFESSIONAL_DOCTORATE_MIN_FINDINGS=22
VPROF_STANDARD_PHD_MIN_FINDINGS=26

# ---------- DeepSeek model roles ----------
DEEPSEEK_FAST_MODEL=deepseek-v4-pro
DEEPSEEK_QUALITY_MODEL=deepseek-v4-pro
DEEPSEEK_REVIEW_MODEL=deepseek-v4-pro
DEEPSEEK_ADVANCED_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_ENABLED=true
DEEPSEEK_REASONING_EFFORT=max
DEEPSEEK_ADVANCED_PRIMARY_REASONING_EFFORT=max
DEEPSEEK_ADVANCED_REASONING_EFFORT=max

# ---------- OpenAI model roles ----------
OPENAI_FAST_MODEL=gpt-5.6-terra
OPENAI_CHAPTER_MODEL=gpt-5.6-terra
OPENAI_CHAPTER_REASONING_EFFORT=high
OPENAI_EXPERT_MODEL=gpt-5.6-terra
OPENAI_EXPERT_REASONING_EFFORT=high
OPENAI_FINAL_AUDIT_MODEL=gpt-5.6-terra
OPENAI_FINAL_AUDIT_REASONING_EFFORT=high
OPENAI_NON_RESEARCH_MASTERS_AUDIT_REASONING_EFFORT=medium
OPENAI_RESEARCH_MASTERS_AUDIT_REASONING_EFFORT=high
OPENAI_PROFESSIONAL_DOCTORATE_AUDIT_REASONING_EFFORT=high
OPENAI_PHD_AUDIT_REASONING_EFFORT=xhigh
OPENAI_EXTERNAL_DOMAIN_MODEL=gpt-5.6-terra
OPENAI_EXTERNAL_DOMAIN_REASONING_EFFORT=high
OPENAI_EXTERNAL_ADJUDICATOR_MODEL=gpt-5.6-terra
OPENAI_EXTERNAL_ADJUDICATOR_REASONING_EFFORT=xhigh

# ---------- Review quality, speed and request limits ----------
AI_CONFIDENCE_THRESHOLD=0.78
AI_MAX_CONTEXT_CHARS_PER_RULE=9000
AI_MAX_MAP_INPUT_CHARS=30000
AI_MAX_OUTPUT_TOKENS=12000
AI_TIMEOUT_SECONDS=300
AI_FAST_REQUEST_TIMEOUT_SECONDS=120
AI_FAST_REQUEST_MAX_RETRIES=0
AI_MAX_RETRIES=0
AI_STRUCTURED_OUTPUT_RETRIES=0
AI_STRICT_FAILURE=false
AI_JOB_MAX_SECONDS=5400
AI_MAX_PARALLEL_CALLS=4

# ---------- Chapter packet execution ----------
AI_CHAPTER_REVIEW_CONCURRENCY=2
AI_CHAPTER_PACKET_MAX_CHARS=120000
AI_CHAPTER_RECOVERY_CONCURRENCY=1
AI_CHAPTER_RECOVERY_MAX_OUTPUT_TOKENS=7000
AI_VERIFICATION_BATCH_SIZE=12

# ---------- Review depth output limits ----------
AI_LIGHT_MAX_OUTPUT_TOKENS=4500
AI_STANDARD_MAX_OUTPUT_TOKENS=6500
AI_NON_RESEARCH_MASTERS_MAX_OUTPUT_TOKENS=7500
AI_RESEARCH_MASTERS_MAX_OUTPUT_TOKENS=12000
AI_PROFESSIONAL_DOCTORATE_MAX_OUTPUT_TOKENS=11000
AI_PHD_MAX_OUTPUT_TOKENS=12000
AI_ADVANCED_MAX_OUTPUT_TOKENS=12000
AI_LIGHT_AUDIT_MAX_OUTPUT_TOKENS=2600
AI_STANDARD_AUDIT_MAX_OUTPUT_TOKENS=3800
AI_NON_RESEARCH_MASTERS_AUDIT_MAX_OUTPUT_TOKENS=4500
AI_RESEARCH_MASTERS_AUDIT_MAX_OUTPUT_TOKENS=9000
AI_PROFESSIONAL_DOCTORATE_AUDIT_MAX_OUTPUT_TOKENS=7500
AI_PHD_AUDIT_MAX_OUTPUT_TOKENS=8000
AI_ADVANCED_AUDIT_MAX_OUTPUT_TOKENS=8000
AI_ADVANCED_AUDIT_MAX_FINDINGS=24
AI_FAST_AUDIT_BATCH_ISSUE_LIMIT=100
AI_FAST_AUDIT_MAX_BATCHES=1
AI_ADVANCED_SECOND_PASS=true

# ---------- Section and recovery controls ----------
AI_LIGHT_SECTION_BATCH_SIZE=6
AI_SECTION_BATCH_SIZE=3
AI_ADVANCED_SECTION_BATCH_SIZE=4
AI_RECOVERY_BATCH_SIZE=4
AI_MAX_RECOVERY_BATCHES=3
AI_MAX_SHORT_SECTION_FALLBACKS=2
AI_MAX_UNRESOLVED_SECTION_FALLBACKS=2
AI_FOCUSED_RECOVERY_PARALLEL_CALLS=2
AI_FOCUSED_RECOVERY_MAX_OUTPUT_TOKENS=4200
AI_FOCUSED_RECOVERY_TIMEOUT_SECONDS=240

# ---------- Checkpoints and automatic recovery ----------
AUTO_RESUME_JOBS=true
MAX_AUTO_RESUMES=3
AUTOMATIC_RETRY_DELAY_SECONDS=12
AUTOMATIC_RETRY_MAX_DELAY_SECONDS=90
JOB_HEARTBEAT_SECONDS=45
JOB_LEASE_SECONDS=240
JOB_STALE_AFTER_SECONDS=180
STAGE_STALE_AFTER_SECONDS=1800

# ---------- External examination ----------
AI_EXTERNAL_ASSESSMENT_FOUNDATION_MAX_OUTPUT_TOKENS=8000
AI_EXTERNAL_ASSESSMENT_EVIDENCE_MAX_OUTPUT_TOKENS=8000
AI_EXTERNAL_ASSESSMENT_INTEGRITY_MAX_OUTPUT_TOKENS=6500
AI_EXTERNAL_ASSESSMENT_ADJUDICATION_MAX_OUTPUT_TOKENS=11000
AI_EXTERNAL_ASSESSMENT_STAGE_TIMEOUT_SECONDS=900
AI_EXTERNAL_ASSESSMENT_REQUEST_TIMEOUT_SECONDS=360
AI_EXTERNAL_ASSESSMENT_REQUEST_MAX_RETRIES=0

# ---------- Token accounting ----------
TOKEN_ACCOUNTING_ENABLED=true
TOKEN_QUOTA_ENFORCEMENT=false
SUPERVISOR_DEFAULT_TOKEN_ALLOCATION=0
TOKEN_ESTIMATE_WORDS_PER_PAGE=450
TOKEN_RESERVE_MULTIPLIER=1.15
TOKENS_PER_PAGE_SUPERVISORY_LIGHT=2500
TOKENS_PER_PAGE_SUPERVISORY_STANDARD=3500
TOKENS_PER_PAGE_SUPERVISORY_ADVANCED=5000
TOKENS_PER_PAGE_EXTERNAL_ASSESSMENT=6500
MAX_SUPERVISOR_TOKEN_ALLOCATION=100000000000

# ---------- Cost estimation rates ----------
# These values affect internal estimates only, not provider billing.
PRICE_DEEPSEEK_FLASH_INPUT=0.14
PRICE_DEEPSEEK_FLASH_CACHED_INPUT=0.0028
PRICE_DEEPSEEK_FLASH_OUTPUT=0.28
PRICE_DEEPSEEK_PRO_INPUT=0.435
PRICE_DEEPSEEK_PRO_CACHED_INPUT=0.003625
PRICE_DEEPSEEK_PRO_OUTPUT=0.87
PRICE_OPENAI_FAST_INPUT=0.20
PRICE_OPENAI_FAST_CACHED_INPUT=0.02
PRICE_OPENAI_FAST_OUTPUT=1.25
PRICE_OPENAI_CHAPTER_INPUT=0.75
PRICE_OPENAI_CHAPTER_CACHED_INPUT=0.075
PRICE_OPENAI_CHAPTER_OUTPUT=4.50
PRICE_OPENAI_EXPERT_INPUT=2.50
PRICE_OPENAI_EXPERT_CACHED_INPUT=0.25
PRICE_OPENAI_EXPERT_OUTPUT=15.00
