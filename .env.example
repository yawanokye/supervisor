# Hybrid AI review
AI_REVIEW_ENABLED=true

# DeepSeek performs low-cost document mapping and the primary academic review.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_EXTRACT_MODEL=deepseek-v4-flash
DEEPSEEK_REVIEW_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high

# OpenAI verifies critical, uncertain, manual, and disputed decisions.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VERIFY_MODEL=gpt-5.4
OPENAI_PREMIUM_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium

# Routing and cost controls
AI_CONFIDENCE_THRESHOLD=0.82
AI_MAX_RULES_PER_BATCH=5
AI_MAX_CONTEXT_CHARS_PER_RULE=12000
AI_MAX_MAP_INPUT_CHARS=36000
AI_MAX_OUTPUT_TOKENS=7000
AI_MAX_PARALLEL_CALLS=2
AI_TIMEOUT_SECONDS=150
AI_MAX_RETRIES=2
AI_USE_FLASH_DOCUMENT_MAP=true
AI_VERIFY_CRITICAL=true
AI_VERIFY_MANUAL=true
AI_VERIFY_DISAGREEMENT=true
AI_VERIFY_MEETS_SAMPLE_RATE=0.10
AI_STRICT_FAILURE=false

# Optional price overrides per 1M tokens. Used only for estimated cost reporting.
PRICE_DEEPSEEK_FLASH_INPUT=0.14
PRICE_DEEPSEEK_FLASH_CACHED_INPUT=0.0028
PRICE_DEEPSEEK_FLASH_OUTPUT=0.28
PRICE_DEEPSEEK_PRO_INPUT=0.435
PRICE_DEEPSEEK_PRO_CACHED_INPUT=0.003625
PRICE_DEEPSEEK_PRO_OUTPUT=0.87
PRICE_OPENAI_VERIFY_INPUT=2.50
PRICE_OPENAI_VERIFY_CACHED_INPUT=0.25
PRICE_OPENAI_VERIFY_OUTPUT=15.00
PRICE_OPENAI_PREMIUM_INPUT=5.00
PRICE_OPENAI_PREMIUM_CACHED_INPUT=0.50
PRICE_OPENAI_PREMIUM_OUTPUT=30.00
