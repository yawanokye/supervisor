AI_REVIEW_ENABLED=true

# =========================================================
# v1.9.9.10 OPENAI-ONLY, WORKER-FIRST PRODUCTION SETUP
# This avoids DeepSeek quality issues and removes unavailable preview models.
# The web app queues jobs. The worker runs AI review and DOCX export.
# =========================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
VPROF_ENABLE_OPENAI=true
VPROF_ENABLE_DEEPSEEK=false
VPROF_ENABLE_SELECTIVE_ESCALATION=true
VPROF_ROUTING_PROFILE=quality
VPROF_COMBINED_APP_PIPELINE=true
VPROF_EXPERT_PROVIDER_MODE=combined_openai_pipeline

# =========================================================
# SHARED STORAGE FOR WEB + WORKER
# A separate Render worker cannot read the web service's persistent disk.
# Keep VPROF_DB_ARTIFACT_STORAGE=true unless you add S3/R2/object storage.
# =========================================================
DATABASE_URL=postgresql+psycopg://user:password@host:5432/vprofessor
VPROF_DB_ARTIFACT_STORAGE=true
VPROF_RUN_JOBS_IN_WEB=false
VPROF_WORKER_CONCURRENCY=1
VPROF_WORKER_POLL_SECONDS=8
REVIEW_STORAGE_DIR=/tmp/vprofessor/reviews
REVIEW_STORAGE_FALLBACK_DIR=/tmp/vprofessor/reviews
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true

# =========================================================
# OPENAI MODEL ROLES, COST-AWARE BUT STANDARD QUALITY
# Do not use gpt-5.6-luna unless your OpenAI organisation confirms access.
# =========================================================
OPENAI_FAST_MODEL=gpt-5.6-terra
OPENAI_CLEANING_MODEL=gpt-5.6-terra
OPENAI_CHAPTER_MODEL=gpt-5.6-terra
OPENAI_SECTION_ANALYSIS_MODEL=gpt-5.6-terra
OPENAI_SECTION_ANALYSIS_FALLBACK_MODEL=gpt-5.6-terra
OPENAI_EXPERT_MODEL=gpt-5.6-terra
OPENAI_FINAL_AUDIT_MODEL=gpt-5.6-terra
OPENAI_FINAL_SYNTHESIS_MODEL=gpt-5.6-terra
OPENAI_FINAL_SYNTHESIS_FALLBACK_MODEL=gpt-5.6-terra
OPENAI_EXTERNAL_DOMAIN_MODEL=gpt-5.6-terra
OPENAI_EXTERNAL_ADJUDICATOR_MODEL=gpt-5.6-terra

# GPT-5.6 model pricing used for internal cost accounting (USD per 1M tokens)
PRICE_OPENAI_TERRA_INPUT=2.50
PRICE_OPENAI_TERRA_CACHED_INPUT=0.25
PRICE_OPENAI_TERRA_OUTPUT=15.00
PRICE_OPENAI_SOL_INPUT=5.00
PRICE_OPENAI_SOL_CACHED_INPUT=0.50
PRICE_OPENAI_SOL_OUTPUT=30.00

OPENAI_CHAPTER_REASONING_EFFORT=medium
OPENAI_EXPERT_REASONING_EFFORT=high
OPENAI_FINAL_AUDIT_REASONING_EFFORT=high
OPENAI_NON_RESEARCH_MASTERS_AUDIT_REASONING_EFFORT=medium
OPENAI_RESEARCH_MASTERS_AUDIT_REASONING_EFFORT=high
OPENAI_PROFESSIONAL_DOCTORATE_AUDIT_REASONING_EFFORT=high
OPENAI_PHD_AUDIT_REASONING_EFFORT=high
OPENAI_EXTERNAL_DOMAIN_REASONING_EFFORT=high
OPENAI_EXTERNAL_ADJUDICATOR_REASONING_EFFORT=high

# =========================================================
# COST AND SPEED GUARDS
# =========================================================
VPROF_DEFAULT_CALL_BUDGET_USD=0.45
VPROF_EXTERNAL_CALL_BUDGET_USD=1.50
AI_MAX_PARALLEL_CALLS=2
AI_CHAPTER_REVIEW_CONCURRENCY=2
AI_CHAPTER_RECOVERY_CONCURRENCY=1
AI_CHAPTER_PACKET_MAX_CHARS=60000
AI_CHAPTER_RECOVERY_MAX_OUTPUT_TOKENS=4500
AI_TIMEOUT_SECONDS=300
AI_FAST_REQUEST_TIMEOUT_SECONDS=180
AI_FAST_REQUEST_MAX_RETRIES=0
AI_MAX_RETRIES=0
AI_STRUCTURED_OUTPUT_RETRIES=0
AI_JOB_MAX_SECONDS=5400
AI_ADVANCED_SECOND_PASS=true

AI_LIGHT_MAX_OUTPUT_TOKENS=3500
AI_STANDARD_MAX_OUTPUT_TOKENS=5500
AI_NON_RESEARCH_MASTERS_MAX_OUTPUT_TOKENS=6500
AI_RESEARCH_MASTERS_MAX_OUTPUT_TOKENS=7500
AI_PROFESSIONAL_DOCTORATE_MAX_OUTPUT_TOKENS=8500
AI_PHD_MAX_OUTPUT_TOKENS=9000
AI_ADVANCED_MAX_OUTPUT_TOKENS=9000
AI_LIGHT_AUDIT_MAX_OUTPUT_TOKENS=2600
AI_STANDARD_AUDIT_MAX_OUTPUT_TOKENS=3200
AI_NON_RESEARCH_MASTERS_AUDIT_MAX_OUTPUT_TOKENS=4000
AI_RESEARCH_MASTERS_AUDIT_MAX_OUTPUT_TOKENS=5000
AI_PROFESSIONAL_DOCTORATE_AUDIT_MAX_OUTPUT_TOKENS=5500
AI_PHD_AUDIT_MAX_OUTPUT_TOKENS=6000

AI_EXTERNAL_ASSESSMENT_FOUNDATION_MAX_OUTPUT_TOKENS=5500
AI_EXTERNAL_ASSESSMENT_EVIDENCE_MAX_OUTPUT_TOKENS=5500
AI_EXTERNAL_ASSESSMENT_INTEGRITY_MAX_OUTPUT_TOKENS=4500
AI_EXTERNAL_ASSESSMENT_ADJUDICATION_MAX_OUTPUT_TOKENS=7500
AI_EXTERNAL_ASSESSMENT_STAGE_TIMEOUT_SECONDS=900
AI_EXTERNAL_ASSESSMENT_REQUEST_TIMEOUT_SECONDS=300
AI_EXTERNAL_ASSESSMENT_REQUEST_MAX_RETRIES=0

# =========================================================
# CHECKPOINT RECOVERY
# =========================================================
AUTO_RESUME_JOBS=true
MAX_AUTO_RESUMES=2
JOB_HEARTBEAT_SECONDS=30
JOB_LEASE_SECONDS=180
JOB_STALE_AFTER_SECONDS=240
RECOVERY_STALLED_AFTER_SECONDS=600
CLIENT_AUTO_RECOVERY_SECONDS=600

# =========================================================
# COMMENT QUALITY AND NATIVE DOCX OUTPUT
# =========================================================
VPROF_REJECT_PLACEHOLDER_COMMENTS=true
VPROF_SUPPRESS_INTERNAL_AUDIT_NOTICES=true
VPROF_COMMENT_MAX_CHARS=1100
VPROF_COMMENT_SIMILARITY_THRESHOLD=0.58
VPROF_DEVELOPMENTAL_COMMENTS=true
VPROF_COMMENT_DEPTH_FLOOR_ENABLED=false
VPROF_INLINE_ANNOTATED_EXPORT=true
VPROF_DETERMINISTIC_SUPERVISORY_CHECKLIST=true
VPROF_HARD_SUPERVISORY_CHECKLIST=true
VPROF_EVIDENCE_SAFE_CHECKLIST=true
VPROF_UCC_SECTION_COVERAGE_CONTRACT=true
VPROF_PRESERVE_UCC_SECTION_COMMENTS=true

TOKEN_ACCOUNTING_ENABLED=true
TOKEN_QUOTA_ENFORCEMENT=false
SUPERVISOR_DEFAULT_TOKEN_ALLOCATION=0
MAX_SUPERVISOR_TOKEN_ALLOCATION=100000000000

# Native DOCX export reconciliation and richer comments
VPROF_NATIVE_COMMENT_STYLE=one_per_finding
VPROF_EXPORT_ONE_COMMENT_PER_FINDING=true
VPROF_COMMENT_MERGE_BY_SECTION=false
VPROF_MAX_ITEMS_PER_NATIVE_COMMENT=1
VPROF_INCLUDE_SECTION_REVIEW_COMMENTS=false
VPROF_SPLIT_RELATED_CONCERNS_INTO_SEPARATE_COMMENTS=true
VPROF_VERIFY_DOCX_COMMENT_COUNT=true
VPROF_SHOW_FINDING_COMMENT_RECONCILIATION=true
VPROF_MISSING_SECTION_INLINE_BOTTOM=true
VPROF_NATIVE_GROUP_LOCATION_MARKERS=true
VPROF_SEQUENTIAL_COMMENT_REFERENCES=true
VPROF_SPECIFIC_CORRECTIONS_REQUIRED_BOTTOM=true


# v1.9.9.16: level-appropriate thorough thesis review defaults
VPROF_STANDARD_NON_RESEARCH_MIN_FINDINGS=0
VPROF_STANDARD_RESEARCH_MASTERS_MIN_FINDINGS=0
VPROF_STANDARD_PROFESSIONAL_DOCTORATE_MIN_FINDINGS=0
VPROF_STANDARD_PHD_MIN_FINDINGS=0
VPROF_COMMENT_DEPTH_FLOOR_ENABLED=false
VPROF_DEVELOPMENTAL_COMMENTS=true
VPROF_SEQUENTIAL_COMMENT_REFERENCES=true
VPROF_SPECIFIC_CORRECTIONS_REQUIRED_BOTTOM=true
VPROF_NATIVE_COMMENT_STYLE=one_per_finding
VPROF_MAX_ITEMS_PER_NATIVE_COMMENT=1
VPROF_INCLUDE_SECTION_REVIEW_COMMENTS=false
VPROF_VERIFY_DOCX_COMMENT_COUNT=true
VPROF_SHOW_FINDING_COMMENT_RECONCILIATION=true

# v1.9.9.17: generic method-results-discussion audit
# These controls document the intended behaviour: the audit detects the actual analysis route
# from the submitted work and applies route-specific checks only when relevant.
VPROF_GENERIC_METHOD_RESULTS_AUDIT=true
VPROF_ANALYSIS_ROUTE_DETECTION=true
VPROF_METHOD_SPECIFIC_DIAGNOSTICS=true
VPROF_EVIDENCE_PRESERVING_REVIEW=true

# v1.9.9.18: ArticleReady-style report-first supervisor review
# The review engine first produces a substantive evidence-preserving report, then exports actionable comments.
VPROF_ARTICLEREADY_REVIEW_ENGINE=true
VPROF_NATIVE_DOCX_DELIVERY_ONLY=true
VPROF_REPORT_FIRST_REVIEW=true
VPROF_SAFE_COMMENT_MARKER_ANCHORS=true

# Professional reviewer/examiner pipeline
VPROF_PROFESSIONAL_REVIEW_PIPELINE=true
VPROF_SCOPE_SPECIFIC_REPORTS=true
VPROF_CANONICAL_FINDING_LEDGER=true
VPROF_FINDING_QUOTAS_ENABLED=false
VPROF_FULL_THESIS_EXAMINER_MODE=true
# v1.9.9.22: systematic coverage-driven professional review
VPROF_SYSTEMATIC_COVERAGE_REVIEW=true
VPROF_COVERAGE_PARAGRAPHS_PER_UNIT=7
VPROF_COVERAGE_CONTEXT_PARAGRAPHS=1
VPROF_COVERAGE_UNIT_MAX_CHARS=12000
VPROF_COVERAGE_TABLE_ROWS_PER_UNIT=10
VPROF_COVERAGE_UNITS_PER_REQUEST=4
VPROF_COVERAGE_HIGH_RISK_UNITS_PER_REQUEST=2
VPROF_COVERAGE_REQUEST_MAX_CHARS=28000
VPROF_COVERAGE_RELEASE_GATE=true
VPROF_FINDING_QUOTAS_ENABLED=false
VPROF_COMMENT_DEPTH_FLOOR_ENABLED=false
VPROF_STANDARD_NON_RESEARCH_MIN_FINDINGS=0
VPROF_STANDARD_RESEARCH_MASTERS_MIN_FINDINGS=0
VPROF_STANDARD_PROFESSIONAL_DOCTORATE_MIN_FINDINGS=0
VPROF_STANDARD_PHD_MIN_FINDINGS=0


# v1.9.9.23: clear student-facing comments and table-level analytical audit
VPROF_STUDENT_FRIENDLY_COMMENTS=true
VPROF_CONTEXT_SPECIFIC_EXAMPLES=true
VPROF_STATISTICAL_TABLE_AUDIT=true
VPROF_ANALYSIS_APPROPRIATENESS_AUDIT=true

# v1.9.9.24 specification-aligned professional supervision
VPROF_SPEC_ALIGNED_SUPERVISORY_REPORT=true
VPROF_COVERAGE_STATUS_LEDGER=true
VPROF_MEASUREMENT_AUDIT=true
VPROF_REFERENCE_RECONCILIATION_AUDIT=true
VPROF_REQUIRE_STATISTICAL_AUDIT_FOR_RESULTS=true

# v1.9.9.25 final review reconciliation and natural student guidance
VPROF_ADD_QUALITY_EXPECTATION_TO_COMMENTS=false
VPROF_INCLUDE_DEGREE_LABEL_IN_COMMENTS=false
VPROF_REPORT_INCLUDE_DETAILED_FINDINGS=false
VPROF_REPORT_MAX_DETAILED_FINDINGS=30
VPROF_INTRO_BACKGROUND_SYNTHESIS_MODE=focused
VPROF_FINAL_COMMENT_RECONCILIATION=true

# v1.9.9.26 final all-level section and whole-document coverage
VPROF_REQUIRED_SECTION_RELEASE_RECONCILIATION=true
VPROF_FULL_DOCUMENT_COMPONENT_AUDIT=true
VPROF_UCC_SECTION_CONTRACT_MAX_ISSUES=500
