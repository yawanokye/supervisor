AI_REVIEW_ENABLED=true

# OpenAI tiered expert-review workflow through the Responses API.
# GPT-5.4 mini handles fast chapter review. GPT-5.4 handles factual audits,
# research-intensive methods/results sections and external examination.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAPTER_MODEL=gpt-5.4-mini
OPENAI_CHAPTER_REASONING_EFFORT=high
OPENAI_EXPERT_MODEL=gpt-5.4
OPENAI_EXPERT_REASONING_EFFORT=high
OPENAI_FINAL_AUDIT_MODEL=gpt-5.4
OPENAI_FINAL_AUDIT_REASONING_EFFORT=high
OPENAI_EXTERNAL_MODEL=gpt-5.4
OPENAI_EXTERNAL_REASONING_EFFORT=high
OPENAI_EXTERNAL_DECISION_REASONING_EFFORT=xhigh

# Remove any old OPENAI_REVIEW_MODEL=o3-mini setting from Render. The active
# workflow uses the role-specific variables above.

# Legacy provider variables are inactive and may remain unset.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_REVIEW_MODEL=deepseek-v4-pro
DEEPSEEK_ADVANCED_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_ENABLED=true
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_ADVANCED_PRIMARY_REASONING_EFFORT=high
DEEPSEEK_ADVANCED_REASONING_EFFORT=max

# Review execution
AI_MAX_PARALLEL_CALLS=4
AI_LIGHT_SECTION_BATCH_SIZE=6
AI_SECTION_BATCH_SIZE=5
AI_ADVANCED_SECTION_BATCH_SIZE=4
AI_VERIFICATION_BATCH_SIZE=24
AI_RECOVERY_BATCH_SIZE=6
AI_MAX_RECOVERY_BATCHES=2
AI_MAX_SHORT_SECTION_FALLBACKS=2
AI_ADVANCED_AUDIT_MAX_FINDINGS=24
AI_TIMEOUT_SECONDS=300
AI_JOB_MAX_SECONDS=5400

# Durable checkpoint, heartbeat and automatic resume
AUTO_RESUME_JOBS=true
MAX_AUTO_RESUMES=3
JOB_HEARTBEAT_SECONDS=45
JOB_LEASE_SECONDS=240
JOB_STALE_AFTER_SECONDS=180
AI_MAX_RETRIES=1
AI_STRUCTURED_OUTPUT_RETRIES=0
AI_STRICT_FAILURE=false
AI_ADVANCED_SECOND_PASS=true

AI_LIGHT_MAX_OUTPUT_TOKENS=7000
AI_STANDARD_MAX_OUTPUT_TOKENS=9000
AI_ADVANCED_MAX_OUTPUT_TOKENS=12000
AI_ADVANCED_AUDIT_MAX_OUTPUT_TOKENS=8000

# External Assessment uses three parallel evidence-analysis stages followed by
# two parallel synthesis stages. Smaller prompts reduce latency while evidence
# validation and recommendation consistency checks preserve review quality.
AI_EXTERNAL_ASSESSMENT_FOUNDATION_MAX_OUTPUT_TOKENS=8000
AI_EXTERNAL_ASSESSMENT_EVIDENCE_MAX_OUTPUT_TOKENS=8000
AI_EXTERNAL_ASSESSMENT_INTEGRITY_MAX_OUTPUT_TOKENS=6500
AI_EXTERNAL_ASSESSMENT_CORRECTIONS_MAX_OUTPUT_TOKENS=8000
AI_EXTERNAL_ASSESSMENT_DECISION_MAX_OUTPUT_TOKENS=5000
AI_EXTERNAL_ASSESSMENT_STAGE_TIMEOUT_SECONDS=900
AI_EXTERNAL_ASSESSMENT_REQUEST_TIMEOUT_SECONDS=360
AI_EXTERNAL_ASSESSMENT_REQUEST_MAX_RETRIES=0

# Optional cost tracking. Update if OpenAI pricing changes.
PRICE_OPENAI_CHAPTER_INPUT=0.75
PRICE_OPENAI_CHAPTER_CACHED_INPUT=0.075
PRICE_OPENAI_CHAPTER_OUTPUT=4.50
PRICE_OPENAI_EXPERT_INPUT=2.50
PRICE_OPENAI_EXPERT_CACHED_INPUT=0.25
PRICE_OPENAI_EXPERT_OUTPUT=15.00

# Institutional accounts and sessions
DATABASE_URL=sqlite:///./supervisor.db
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-temporary-password
ADMIN_NAME=System Administrator
ADMIN_EMAIL=

# Production checkpoint storage. Attach a persistent disk at /var/data or use a shared object-storage implementation.
REVIEW_STORAGE_DIR=/var/data/reviews
REVIEW_STORAGE_FALLBACK_DIR=/tmp/projectready-supervisor/reviews
