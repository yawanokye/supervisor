AI_REVIEW_ENABLED=true

# =========================================================
# v1.9.8.5 ALL-LEVEL DEGREE-CALIBRATED DEPTH AND COST CONTROL
# economy | balanced | quality
# Balanced is recommended for production.
# =========================================================
VPROF_ROUTING_PROFILE=quality
VPROF_ENABLE_OPENAI=false
VPROF_ENABLE_DEEPSEEK=true
VPROF_ENABLE_SELECTIVE_ESCALATION=false
VPROF_ESCALATE_CONFIDENCE_BELOW=0.78
VPROF_DEFAULT_CALL_BUDGET_USD=0.25
VPROF_EXTERNAL_CALL_BUDGET_USD=2.00

# Every programme level uses its own review contract, issue capacity, output
# budget and independent-audit strength. Research degrees use the research-
# intensive route, while applied programmes retain the cost-efficient route.
VPROF_ALL_LEVELS_DEGREE_CALIBRATED=true
VPROF_RESEARCH_MASTERS_DEEP_REVIEW=true

# ---------- Expert DeepSeek V4 Pro-only route ----------
# Enables one stronger DeepSeek Pro route for all supervisory review stages.
VPROF_EXPERT_PROVIDER_MODE=deepseek_v4_pro_only
VPROF_FORCE_DEEPSEEK_V4_PRO=true

# =========================================================
# PROVIDER KEYS
# Add both keys for the recommended balanced workflow.
# Normal reviews can continue with one provider if the other is unavailable.
# External examination still requires OpenAI for the degree recommendation.
# =========================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# =========================================================
# MODEL ROLES
# =========================================================
DEEPSEEK_FAST_MODEL=deepseek-v4-pro
DEEPSEEK_QUALITY_MODEL=deepseek-v4-pro
# The router disables thinking for Flash first-pass reviews even when this is
# true. Pro and advanced tasks retain thinking mode.
DEEPSEEK_THINKING_ENABLED=true
DEEPSEEK_REASONING_EFFORT=max
DEEPSEEK_ADVANCED_PRIMARY_REASONING_EFFORT=max
DEEPSEEK_ADVANCED_REASONING_EFFORT=max

OPENAI_FAST_MODEL=gpt-5.4-nano
OPENAI_CHAPTER_MODEL=gpt-5.4-mini
OPENAI_CHAPTER_REASONING_EFFORT=high
OPENAI_EXPERT_MODEL=gpt-5.4
OPENAI_EXPERT_REASONING_EFFORT=high
OPENAI_FINAL_AUDIT_MODEL=gpt-5.4
OPENAI_FINAL_AUDIT_REASONING_EFFORT=high
OPENAI_NON_RESEARCH_MASTERS_AUDIT_REASONING_EFFORT=medium
OPENAI_RESEARCH_MASTERS_AUDIT_REASONING_EFFORT=high
OPENAI_PROFESSIONAL_DOCTORATE_AUDIT_REASONING_EFFORT=high
OPENAI_PHD_AUDIT_REASONING_EFFORT=xhigh

# External examination uses three domain examiners in parallel followed by one
# adjudicator. DeepSeek Pro is used only as a provider-failure fallback.
OPENAI_EXTERNAL_DOMAIN_MODEL=gpt-5.4
OPENAI_EXTERNAL_DOMAIN_REASONING_EFFORT=high
OPENAI_EXTERNAL_ADJUDICATOR_MODEL=gpt-5.4
OPENAI_EXTERNAL_ADJUDICATOR_REASONING_EFFORT=xhigh

# Remove stale OPENAI_REVIEW_MODEL=o3-mini from Render. The role-specific
# variables above are authoritative.

# =========================================================
# REVIEW EXECUTION AND SPEED
# =========================================================
AI_MAX_PARALLEL_CALLS=4
AI_CHAPTER_REVIEW_CONCURRENCY=2
AI_CHAPTER_PACKET_MAX_CHARS=80000
AI_CHAPTER_RECOVERY_CONCURRENCY=1
AI_CHAPTER_RECOVERY_MAX_OUTPUT_TOKENS=7000
AI_VERIFICATION_BATCH_SIZE=12
AI_TIMEOUT_SECONDS=300
AI_FAST_REQUEST_TIMEOUT_SECONDS=240
AI_FAST_REQUEST_MAX_RETRIES=0
AI_JOB_MAX_SECONDS=5400
AI_MAX_RETRIES=0
AI_STRUCTURED_OUTPUT_RETRIES=1
AI_STRICT_FAILURE=false
AI_ADVANCED_SECOND_PASS=true

AI_LIGHT_MAX_OUTPUT_TOKENS=4500
AI_STANDARD_MAX_OUTPUT_TOKENS=9000
AI_NON_RESEARCH_MASTERS_MAX_OUTPUT_TOKENS=7500
AI_RESEARCH_MASTERS_MAX_OUTPUT_TOKENS=12000
AI_PROFESSIONAL_DOCTORATE_MAX_OUTPUT_TOKENS=11000
AI_PHD_MAX_OUTPUT_TOKENS=12000
AI_ADVANCED_MAX_OUTPUT_TOKENS=12000
AI_LIGHT_AUDIT_MAX_OUTPUT_TOKENS=2600
AI_STANDARD_AUDIT_MAX_OUTPUT_TOKENS=3800
AI_NON_RESEARCH_MASTERS_AUDIT_MAX_OUTPUT_TOKENS=4500
AI_RESEARCH_MASTERS_AUDIT_MAX_OUTPUT_TOKENS=9000
AI_PROFESSIONAL_DOCTORATE_AUDIT_MAX_OUTPUT_TOKENS=7500
AI_PHD_AUDIT_MAX_OUTPUT_TOKENS=8000
AI_FAST_AUDIT_BATCH_ISSUE_LIMIT=100
AI_FAST_AUDIT_MAX_BATCHES=1
AI_ADVANCED_AUDIT_MAX_OUTPUT_TOKENS=8000

# Legacy section settings remain accepted for backwards compatibility.
AI_LIGHT_SECTION_BATCH_SIZE=3
AI_SECTION_BATCH_SIZE=2
AI_ADVANCED_SECTION_BATCH_SIZE=4
AI_RECOVERY_BATCH_SIZE=4
AI_MAX_RECOVERY_BATCHES=3
AI_MAX_SHORT_SECTION_FALLBACKS=2
AI_ADVANCED_AUDIT_MAX_FINDINGS=24
AI_FOCUSED_RECOVERY_PARALLEL_CALLS=2
AI_FOCUSED_RECOVERY_MAX_OUTPUT_TOKENS=4200
AI_FOCUSED_RECOVERY_TIMEOUT_SECONDS=240
AI_MAX_UNRESOLVED_SECTION_FALLBACKS=2


# =========================================================
# PUBLIC COMMENT QUALITY GATE
# These defaults prevent placeholders, internal audit notices, duplicate
# findings and comments cut in the middle of a sentence.
# =========================================================
VPROF_REJECT_PLACEHOLDER_COMMENTS=true
VPROF_SUPPRESS_INTERNAL_AUDIT_NOTICES=true
VPROF_COMMENT_MAX_CHARS=980
VPROF_COMMENT_SIMILARITY_THRESHOLD=0.58
VPROF_DEVELOPMENTAL_COMMENTS=true
VPROF_COMMENT_DEPTH_FLOOR_ENABLED=true
VPROF_STANDARD_NON_RESEARCH_MIN_FINDINGS=18
VPROF_STANDARD_RESEARCH_MASTERS_MIN_FINDINGS=24
VPROF_STANDARD_PROFESSIONAL_DOCTORATE_MIN_FINDINGS=28
VPROF_STANDARD_PHD_MIN_FINDINGS=32

# =========================================================
# AUTOMATIC CHECKPOINT RECOVERY
# =========================================================
AUTO_RESUME_JOBS=true
MAX_AUTO_RESUMES=3
JOB_HEARTBEAT_SECONDS=45
JOB_LEASE_SECONDS=240
JOB_STALE_AFTER_SECONDS=180

# =========================================================
# EXTERNAL ASSESSMENT
# =========================================================
AI_EXTERNAL_ASSESSMENT_FOUNDATION_MAX_OUTPUT_TOKENS=8000
AI_EXTERNAL_ASSESSMENT_EVIDENCE_MAX_OUTPUT_TOKENS=8000
AI_EXTERNAL_ASSESSMENT_INTEGRITY_MAX_OUTPUT_TOKENS=6500
AI_EXTERNAL_ASSESSMENT_ADJUDICATION_MAX_OUTPUT_TOKENS=11000
AI_EXTERNAL_ASSESSMENT_STAGE_TIMEOUT_SECONDS=900
AI_EXTERNAL_ASSESSMENT_REQUEST_TIMEOUT_SECONDS=360
AI_EXTERNAL_ASSESSMENT_REQUEST_MAX_RETRIES=0

# Legacy external limits remain accepted but are not used by the active flow.
AI_EXTERNAL_ASSESSMENT_CORRECTIONS_MAX_OUTPUT_TOKENS=8000
AI_EXTERNAL_ASSESSMENT_DECISION_MAX_OUTPUT_TOKENS=5000

# =========================================================
# OPTIONAL COST TRACKING OVERRIDES
# Prices are per one million tokens. Leave them unchanged unless provider
# pricing changes.
# =========================================================
PRICE_DEEPSEEK_FLASH_INPUT=0.14
PRICE_DEEPSEEK_FLASH_CACHED_INPUT=0.0028
PRICE_DEEPSEEK_FLASH_OUTPUT=0.28
PRICE_DEEPSEEK_PRO_INPUT=0.435
PRICE_DEEPSEEK_PRO_CACHED_INPUT=0.003625
PRICE_DEEPSEEK_PRO_OUTPUT=0.87
PRICE_OPENAI_CHAPTER_INPUT=0.75
PRICE_OPENAI_CHAPTER_CACHED_INPUT=0.075
PRICE_OPENAI_CHAPTER_OUTPUT=4.50
PRICE_OPENAI_FAST_INPUT=0.20
PRICE_OPENAI_FAST_CACHED_INPUT=0.02
PRICE_OPENAI_FAST_OUTPUT=1.25
PRICE_OPENAI_EXPERT_INPUT=2.50
PRICE_OPENAI_EXPERT_CACHED_INPUT=0.25
PRICE_OPENAI_EXPERT_OUTPUT=15.00

# =========================================================
# INSTITUTIONAL ACCOUNTS AND STORAGE
# =========================================================
DATABASE_URL=sqlite:///./supervisor.db
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-temporary-password
ADMIN_NAME=System Administrator
ADMIN_EMAIL=
REVIEW_STORAGE_DIR=/var/data/reviews
REVIEW_STORAGE_FALLBACK_DIR=/tmp/projectready-supervisor/reviews

# =========================================================
# SUPERVISOR TOKEN ALLOCATION
# Keep enforcement false during initial production observation.
# =========================================================
TOKEN_ACCOUNTING_ENABLED=true
TOKEN_QUOTA_ENFORCEMENT=false
SUPERVISOR_DEFAULT_TOKEN_ALLOCATION=0
TOKEN_ESTIMATE_WORDS_PER_PAGE=450
TOKEN_RESERVE_MULTIPLIER=1.15
TOKENS_PER_PAGE_SUPERVISORY_LIGHT=2500
TOKENS_PER_PAGE_SUPERVISORY_STANDARD=3500
TOKENS_PER_PAGE_SUPERVISORY_ADVANCED=5000
TOKENS_PER_PAGE_EXTERNAL_ASSESSMENT=6500
MAX_SUPERVISOR_TOKEN_ALLOCATION=100000000000

# v1.9.9.0 deterministic supervisory checklist
VPROF_DETERMINISTIC_SUPERVISORY_CHECKLIST=true
VPROF_DETERMINISTIC_CHECKLIST_MAX_ISSUES=48

# v1.9.9.1 hard supervisory checklist gate
VPROF_HARD_SUPERVISORY_CHECKLIST=true
VPROF_DOCX_NO_TITLEPAGE_FALLBACK=true

VPROF_EVIDENCE_SAFE_CHECKLIST=true

VPROF_INLINE_ANNOTATED_EXPORT=true

# v1.9.9.3 all-level strengthened review
VPROF_FINAL_DEGREE_CONTRACT_RESCUE=true

# v1.9.9.4 recovery hard-stop settings
# Prevents browser/server from remaining forever on "Recovering the interrupted stage".
RECOVERY_STALLED_AFTER_SECONDS=600
CLIENT_AUTO_RECOVERY_SECONDS=600
MAX_AUTO_RESUMES=4
AUTO_RESUME_JOBS=true

# v1.9.9.5 Three-model combined thesis pipeline
# Phase 1: cleaning/formatting/JSON repair. Phase 2: section/domain review.
# Phase 3: full-thesis synthesis/audit. Keep the Luna fallback unless your
# OpenAI organisation has explicit GPT-5.6 preview access.
VPROF_COMBINED_APP_PIPELINE=true
VPROF_ENABLE_OPENAI=true
VPROF_ENABLE_DEEPSEEK=false
VPROF_EXPERT_PROVIDER_MODE=combined_openai_pipeline
OPENAI_CLEANING_MODEL=gpt-4.1-nano
OPENAI_SECTION_ANALYSIS_MODEL=gpt-5.6-luna
OPENAI_SECTION_ANALYSIS_FALLBACK_MODEL=gpt-5.4-mini
OPENAI_FINAL_SYNTHESIS_MODEL=gpt-5.5
OPENAI_FINAL_SYNTHESIS_FALLBACK_MODEL=gpt-5.4
PRICE_OPENAI_CLEANING_INPUT=0.10
PRICE_OPENAI_CLEANING_CACHED_INPUT=0.01
PRICE_OPENAI_CLEANING_OUTPUT=0.40
PRICE_OPENAI_SECTION_INPUT=1.00
PRICE_OPENAI_SECTION_CACHED_INPUT=0.10
PRICE_OPENAI_SECTION_OUTPUT=6.00
PRICE_OPENAI_FINAL_INPUT=5.00
PRICE_OPENAI_FINAL_CACHED_INPUT=0.50
PRICE_OPENAI_FINAL_OUTPUT=30.00

# v1.9.9.8 UCC section-level review coverage
VPROF_UCC_SECTION_COVERAGE_CONTRACT=true
VPROF_PRESERVE_UCC_SECTION_COMMENTS=true
VPROF_UCC_SECTION_CONTRACT_MAX_ISSUES=72
