AI_REVIEW_ENABLED=true
OPENAI_API_KEY=
OPENAI_MINI_MODEL=gpt-5.4-mini
OPENAI_REVIEW_MODEL=gpt-5.4
OPENAI_ADVANCED_MODEL=gpt-5.5
OPENAI_MINI_REASONING_EFFORT=low
OPENAI_REVIEW_REASONING_EFFORT=medium
OPENAI_ADVANCED_REASONING_EFFORT=high
AI_MAX_PARALLEL_CALLS=3
AI_LIGHT_SECTION_BATCH_SIZE=3
AI_SECTION_BATCH_SIZE=3
AI_VERIFICATION_BATCH_SIZE=3
AI_TIMEOUT_SECONDS=100
AI_MAX_RETRIES=1
AI_STRICT_FAILURE=false
AI_LIGHT_MAX_OUTPUT_TOKENS=6500
AI_MINI_MAX_OUTPUT_TOKENS=6500
AI_REVIEW_MAX_OUTPUT_TOKENS=8000
AI_ADVANCED_MAX_OUTPUT_TOKENS=9000

# Institutional accounts and sessions
DATABASE_URL=sqlite:///./supervisor.db
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-temporary-password
ADMIN_NAME=System Administrator
ADMIN_EMAIL=

# Use a Render persistent disk for durable review downloads, for example /var/data/reviews
REVIEW_STORAGE_DIR=/tmp/projectready-supervisor/reviews
