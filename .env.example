AI_REVIEW_ENABLED=true

# DeepSeek powers Light, Standard and Advanced Review.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_REVIEW_MODEL=deepseek-v4-pro
DEEPSEEK_ADVANCED_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_ENABLED=true
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_ADVANCED_PRIMARY_REASONING_EFFORT=high
DEEPSEEK_ADVANCED_REASONING_EFFORT=max

# Review execution
AI_MAX_PARALLEL_CALLS=3
AI_LIGHT_SECTION_BATCH_SIZE=6
AI_SECTION_BATCH_SIZE=5
AI_ADVANCED_SECTION_BATCH_SIZE=4
AI_VERIFICATION_BATCH_SIZE=24
AI_RECOVERY_BATCH_SIZE=6
AI_MAX_RECOVERY_BATCHES=2
AI_MAX_SHORT_SECTION_FALLBACKS=2
AI_ADVANCED_AUDIT_MAX_FINDINGS=24
AI_TIMEOUT_SECONDS=180
AI_JOB_MAX_SECONDS=5400
AI_MAX_RETRIES=1
AI_STRUCTURED_OUTPUT_RETRIES=0
AI_STRICT_FAILURE=false
AI_ADVANCED_SECOND_PASS=true

AI_LIGHT_MAX_OUTPUT_TOKENS=3800
AI_STANDARD_MAX_OUTPUT_TOKENS=5200
AI_ADVANCED_MAX_OUTPUT_TOKENS=6800
AI_ADVANCED_AUDIT_MAX_OUTPUT_TOKENS=4800

# Optional cost tracking. Update these values when provider pricing changes.
PRICE_DEEPSEEK_PRO_INPUT=0.435
PRICE_DEEPSEEK_PRO_CACHED_INPUT=0.003625
PRICE_DEEPSEEK_PRO_OUTPUT=0.87

# OpenAI is no longer required for active review routing. These variables may
# remain unset unless a future optional fallback is enabled.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REVIEW_MODEL=gpt-5.4
OPENAI_REVIEW_REASONING_EFFORT=high

# Institutional accounts and sessions
DATABASE_URL=sqlite:///./supervisor.db
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-temporary-password
ADMIN_NAME=System Administrator
ADMIN_EMAIL=

# Safe default. Temporary files are removed on Render restart or redeploy.
REVIEW_STORAGE_DIR=/tmp/projectready-supervisor/reviews
REVIEW_STORAGE_FALLBACK_DIR=/tmp/projectready-supervisor/reviews

# After attaching a Render persistent disk mounted at /var/data, change to:
# REVIEW_STORAGE_DIR=/var/data/reviews
